# URL canónica del sitio (metadata, OG, sitemap, robots). En build y runtime.
NEXT_PUBLIC_SITE_URL=https://colegiolasvioletas.cl

# Cuota de almacenamiento VPS para uploads (noticias, galería, documentos)
MAX_STORAGE_GB=10

# PostgreSQL — Prisma (noticias, galería, documentos)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/las_violetas?schema=public

# Auth.js / NextAuth — acceso oculto en /gestion-violetas (sin enlaces públicos)
AUTH_SECRET=genera_un_secreto_largo_con_openssl_rand_base64_32
# Credenciales del primer administrador (se crean en DB si la tabla Admin está vacía)
ADMIN_EMAIL=admin@colegiolasvioletas.cl
ADMIN_PASSWORD=cambiar_en_produccion

# Cloudflare Turnstile (login + formulario de contacto)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=tu_site_key_de_turnstile
TURNSTILE_SECRET_KEY=tu_secret_key_de_turnstile

# Opcional: prefijo absoluto para apiClient (mismo origen si se deja vacío).
# API_BASE_URL=

# Opcional: Google Analytics (cuando se integre en layout).
# NEXT_PUBLIC_GA_ID=
